# Скопіюйте цей файл у .env (у цій же теці) і заповніть значення.
# .env у .gitignore — токени не потраплять у публічний репозиторій.

# --- Meta / Instagram (обов'язково для публікації) ---
# ID Instagram Professional-акаунта (не username, а числовий IG User ID)
IG_USER_ID=
# Довгоживучий токен доступу (living ~60 днів, потім оновити)
IG_ACCESS_TOKEN=

# --- ChatGPT (потрібно, якщо у поста порожній caption) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# --- Інше ---
# Публічна адреса теки з медіа (наш домен; альтернатива — GitHub Pages)
MEDIA_BASE_URL=https://aloukraine.com/admin/planner/images/
# Рік для дат плану ("1 Aug" -> 2026-08-01)
PLAN_YEAR=2026
